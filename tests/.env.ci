# MTA brand configuration for CI tests
# This file is copied to .upstream-workspace/tests/.env.ci during pull-upstream

EXTENSION_PUBLISHER=redhat
CORE_EXTENSION_NAME=mta-core
JAVA_EXTENSION_NAME=mta-java
JAVASCRIPT_EXTENSION_NAME=mta-javascript
GO_EXTENSION_NAME=mta-go
CSHARP_EXTENSION_NAME=mta-csharp
PACK_EXTENSION_NAME=mta-vscode-extension
TEST_CATEGORY=MTA

# Other test settings can inherit from .env or set as needed:
# OPENAI_API_KEY=''
# VERBOSE=false
# TEST_DATA_DIR='test-data-dir'
